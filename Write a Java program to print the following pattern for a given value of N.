import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        System.out.print("Enter the number of rows (N): ");
        int n = scanner.nextInt();
        
        // Input validation to ensure N is a positive integer
        if (n <= 0) {
            System.out.println("Please enter a positive integer greater than 0.");
        } else {
            printNumberPattern(n);
        }
        
        scanner.close();
    }

    public static void printNumberPattern(int n) {
        // Variable to keep track of the continuous numbers to print
        int currentNumber = 1;
        
        // Outer loop controls the rows
        for (int i = 1; i <= n; i++) {
            // Inner loop controls the columns (elements per row)
            for (int j = 1; j <= i; j++) {
                System.out.print(currentNumber + " ");
                currentNumber++; // Move to the next consecutive number
            }
            // Move to the next line after completing a row
            System.out.println();
        }
    }
}
