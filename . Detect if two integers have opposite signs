#include <stdio.h>
#include <stdbool.h>

bool has_opposite_signs(int a, int b) {
    // Returns true if one is negative and the other is positive/zero
    return (a ^ b) < 0;
}

int main() {
    int x = 4;
    int y = -8;

    if (has_opposite_signs(x, y)) {
        printf("%d and %d have opposite signs.\n", x, y);
    } else {
        printf("%d and %d have the same sign.\n", x, y);
    }

    return 0;
}
