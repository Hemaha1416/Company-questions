#include <stdio.h>
#include <stdlib.h>

// Structure to hold date components
typedef struct {
    int day;
    int month;
    int year;
} Date;

// Function to check the gap between two dates
void checkMonthApart(Date d1, Date d2) {
    // Step 1: Ensure d1 is always the chronologically earlier date
    if ((d1.year > d2.year) || 
        (d1.year == d2.year && d1.month > d2.month) || 
        (d1.year == d2.year && d1.month == d2.month && d1.day > d2.day)) {
        Date temp = d1;
        d1 = d2;
        d2 = temp;
    }

    // Step 2: Calculate total absolute calendar months for both dates
    int total_months_d1 = (d1.year * 12) + d1.month;
    int total_months_d2 = (d2.year * 12) + d2.month;
    int month_diff = total_months_d2 - total_months_d1;

    // Step 3: Evaluate conditions based on month difference and day matching
    if (month_diff == 0) {
        printf("Less than 1 month apart\n");
    } 
    else if (month_diff == 1) {
        if (d2.day == d1.day) {
            printf("Exactly 1 month apart\n");
        } 
        else if (d2.day < d1.day) {
            printf("Less than 1 month apart\n");
        } 
        else {
            printf("More than 1 month apart\n");
        }
    } 
    else { // month_diff > 1
        printf("More than 1 month apart\n");
    }
}

int main() {
    // Test Case 1: Exactly 1 month (June 06 2011 & July 06 2011)
    Date date1 = {6, 6, 2011};
    Date date2 = {6, 7, 2011};
    printf("June 06 2011 & July 06 2011: ");
    checkMonthApart(date1, date2);

    // Test Case 2: Exactly 1 month crossing a year boundary (Dec 15 2010 & Jan 15 2011)
    Date date3 = {15, 12, 2010};
    Date date4 = {15, 1, 2011};
    printf("Dec 15 2010 & Jan 15 2011: ");
    checkMonthApart(date3, date4);

    // Test Case 3: Less than 1 month (Mar 01 2011 & Mar 25 2011)
    Date date5 = {1, 3, 2011};
    Date date6 = {25, 3, 2011};
    printf("Mar 01 2011 & Mar 25 2011: ");
    checkMonthApart(date5, date6);

    // Test Case 4: Less than 1 month with consecutive months (Jan 15 2011 & Feb 14 2011)
    Date date7 = {15, 1, 2011};
    Date date8 = {14, 2, 2011};
    printf("Jan 15 2011 & Feb 14 2011: ");
    checkMonthApart(date7, date8);

    return 0;
}
