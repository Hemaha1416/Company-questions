#include <stdio.h>
#include <stdlib.h>

// Definition for a binary tree node
struct TreeNode {
    int val;
    struct TreeNode *left;
    struct TreeNode *right;
};

// Helper function to allocate a new tree node
struct TreeNode* createNode(int val) {
    struct TreeNode* newNode = (struct TreeNode*)malloc(sizeof(struct TreeNode));
    newNode->val = val;
    newNode->left = NULL;
    newNode->right = NULL;
    return newNode;
}

// Recursive function to merge two binary trees
struct TreeNode* mergeTrees(struct TreeNode* root1, struct TreeNode* root2) {
    // Base Case 1: If Tree 1 node is empty, return Tree 2 node
    if (root1 == NULL) {
        return root2;
    }
    // Base Case 2: If Tree 2 node is empty, return Tree 1 node
    if (root2 == NULL) {
        return root1;
    }

    // If both nodes exist, sum their values
    root1->val = root1->val + root2->val;

    // Recursively merge left and right subtrees
    root1->left = mergeTrees(root1->left, root2->left);
    root1->right = mergeTrees(root1->right, root2->right);

    // Return the merged tree root
    return root1;
}

// Helper function to print tree in-order (Left, Root, Right) to verify results
void printInOrder(struct TreeNode* node) {
    if (node == NULL) return;
    printInOrder(node->left);
    printf("%d ", node->val);
    printInOrder(node->right);
}

int main() {
    // Constructing Tree 1
    //      1
    //     / \
    //    3   2
    struct TreeNode* t1 = createNode(1);
    t1->left = createNode(3);
    t1->right = createNode(2);

    // Constructing Tree 2
    //      2
    //     / \
    //    1   4
    struct TreeNode* t2 = createNode(2);
    t2->left = createNode(1);
    t2->right = createNode(4);

    printf("Tree 1 (In-order): ");
    printInOrder(t1);
    printf("\nTree 2 (In-order): ");
    printInOrder(t2);

    // Merge Tree 2 into Tree 1
    struct TreeNode* mergedTree = mergeTrees(t1, t2);

    printf("\nMerged Tree (In-order): ");
    printInOrder(mergedTree);
    printf("\n");

    return 0;
}
