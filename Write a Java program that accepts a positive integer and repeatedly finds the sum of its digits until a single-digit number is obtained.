import java.util.Scanner;

// 1. Changed the class name to Main to match your file name 'Main.java'
public class Main {
    public static void main(String[] args) {
        // 2. Fixed System.class to System.in
        Scanner scanner = new Scanner(System.in);
        
        System.out.print("Enter a positive integer: ");
        int number = scanner.nextInt();
        
        if (number <= 0) {
            System.out.println("Please enter a valid positive integer.");
        } else {
            int result = findSingleDigitSum(number);
            System.out.println("The single-digit sum is: " + result);
        }
        
        scanner.close();
    }

    public static int findSingleDigitSum(int num) {
        while (num >= 10) {
            int sum = 0;
            while (num > 0) {
                sum += num % 10;
                num /= 10;
            }
            num = sum;
        }
        return num;
    }
}
