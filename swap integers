#include <stdio.h>

int main() {
    int a, b, temp;

    
    printf("Enter the first integer (a): ");
    scanf("%d", &a);

    
    printf("Enter the second integer (b): ");
    scanf("%d", &b);

    printf("\n--- Before Swap ---\n");
    printf("a = %d\n", a);
    printf("b = %d\n", b);

    temp = a;   
    a = b;      
    b = temp;   

    printf("\n--- After Swap ---\n");
    printf("a = %d\n", a);
    printf("b = %d\n", b);

    return 0;
}

