#include <stdio.h>
#include <stdbool.h>

bool is_power_of_two(int x) {
    // Condition 1: x must be strictly greater than 0
    // Condition 2: x & (x - 1) must equal 0
    return (x > 0) && ((x & (x - 1)) == 0);
}

int main() {
    int num;

    printf("Enter an integer: ");
    if (scanf("%d", &num) != 1) {
        return 1;
    }

    if (is_power_of_two(num)) {
        printf("%d is a power of 2.\n", num);
    } else {
        printf("%d is NOT a power of 2.\n", num);
    }

    return 0;
}
