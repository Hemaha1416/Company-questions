
#include <stdio.h>
#include <stdbool.h>

// Function to check if a number is prime
bool is_prime(long long n) {
    if (n <= 1) return false;
    if (n <= 3) return true;
    if (n % 2 == 0 || n % 3 == 0) return false;

    // Check factors up to the square root of n, stepping by 6
    for (long long i = 5; i * i <= n; i += 6) {
        if (n % i == 0 || n % (i + 2) == 0) {
            return false;
        }
    }
    return true;
}

int main() {
    long long x;

    // Read the input number X
    if (scanf("%lld", &x) != 1) {
        return 0;
    }

    // Start looking for the next prime strictly greater than X
    long long current = x + 1;

    // Keep incrementing until a prime number is found
    while (!is_prime(current)) {
        current++;
    }

    // Print the smallest prime greater than X
    printf("%lld\n", current);

    return 0;
}
